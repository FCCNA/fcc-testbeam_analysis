    "                                                           SPR,\n",
    "                                                           ranger,\n",
    "                                                           dt,\n",
    "                                                           nsimS=21,\n",
    "                                                           nsimC=10,\n",
    "                                                           normalize=False,\n",
    "                                                           graphics=False,\n",
    "                                                           Laser_Calib = laser, \n",
    "                                                           run = log_laser[sipm][ampl],\n",
    "                                                           dcr=0)"
   ]
  },
