    "beam = 'e'\n",
    "angle = 120\n",
    "ch = 2\n",
    "laser = True\n",
    "beam_text = r'$e^+$' if beam == 'e' else r'$\\mu^+$'"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Running script for BGO with e at 120 degrees\n",
      "- Runs: [219, 220]\n",
      "- Template from Laser Calibration Waveform\n"
     ]
    }
   ],
   "source": [
    "print(f'Running script for {crystal} with {beam} at {angle} degrees')\n",
    "print(f'- Runs: {runs_info[crystal][beam][angle]}')\n",
    "if not laser:\n",
    "    print('- Template from analytic function')\n",
    "else:\n",
    "    print('- Template from Laser Calibration Waveform')"
   ]
  },
  {
   "cell_type": "raw",
   "metadata": {},
   "source": [
    "print(f'- Rading runs: {runs_info[crystal][beam][angle]}')\n",
    "wf, df = mixing_run(runs_info[crystal][beam][angle])\n",
    "times = wf[0]['times']\n",
    "\n",
    "df[f'amplitude_media_channel{ch}'] = df[f'amplitude_media_channel{ch}'].fillna(0)"
   ]
  },
