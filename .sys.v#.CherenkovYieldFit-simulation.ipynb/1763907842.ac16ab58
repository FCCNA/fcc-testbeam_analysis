   "source": [
    "dt = times[1]-times[0]\n",
    "dt = dt.round(3)\n",
    "ranger = [int(times.min()), int(times.max())]\n",
    "npoints = len(times)\n",
    "interS_template, interC_template, bins = mcj.get_templates(crystal,\n",
