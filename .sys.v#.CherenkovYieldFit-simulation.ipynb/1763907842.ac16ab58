   ],
   "source": [
    "from __init__ import * \n",
    "import __template__new as mcj\n",
    "import numpy as np\n",
    "import argparse\n",
    "import os\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "plt.rcParams.update({\n",
    "          'font.size': 14,\n",
    "          'figure.figsize': (8, 4.5),\n",
    "          'axes.grid': False,\n",
    "          'grid.linestyle': '-',\n",
    "          'grid.alpha': 0.2,\n",
    "          'lines.markersize': 5.0,\n",
    "          'xtick.minor.visible': True,\n",
    "          'xtick.direction': 'in',\n",
    "          'xtick.major.size': 10.0,\n",
    "          'xtick.minor.size': 5.0,\n",
    "          'xtick.top': True,\n",
    "          'ytick.minor.visible': True,\n",
    "          'ytick.direction': 'in',\n",
    "          'ytick.major.size': 10.0,\n",
    "          'ytick.minor.size': 5.0,\n",
    "          'ytick.right': True,\n",
    "          'errorbar.capsize': 0.0,\n",
    "          'figure.max_open_warning': 50,\n",
    "})\n",
    "from scipy.optimize import curve_fit\n",
    "import yaml\n",
    "from iminuit import Minuit\n",
    "from iminuit.cost import LeastSquares\n",
    "import importlib\n",
    "import random\n",
    "\n",
    "\n",
    "with open(\"yaml/setup_config.yaml\", \"r\") as f:\n",
    "    CONFIG = yaml.safe_load(f)\n",
    "    \n",
    "with open('yaml/data.yaml', 'r') as file:\n",
    "    runs_info = yaml.safe_load(file)\n",
    "\n",
    "with open('yaml/laser_calib.yaml', 'r') as file:\n",
    "    log_laser = yaml.safe_load(file)\n",
    "    \n",
    "make_dir('Hardware_Fit')\n",
    "make_dir('Hardware_Fit/parqs')\n",
    "make_dir('Hardware_Fit/figures')\n",
    "make_dir('npys')\n",
    "make_dir('parqs')\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## simulation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 67,
   "metadata": {},
   "outputs": [],
   "source": [
    "crystal = 'BGO'\n",
    "ch = 2\n",
    "laser = True\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 68,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "SiPM parameters: channel 2, sipm 6x6, gain 28db\n",
      "Reading laser calibration runs 477\n",
      "I file npys/Times_477.npy e npys/Mean_Waveform_477.npy esistono già\n"
     ]
    }
   ],
   "source": [
    "if ch == 2:\n",
    "    sipm = '6x6' \n",
    "    gain = '28db'\n",
    "sipm_params = [sipm, gain]\n",
    "print(f'SiPM parameters: channel {ch}, sipm {sipm}, gain {gain}')\n",
    "\n",
    "if laser:\n",
    "    path_data = '/eos/user/m/mcampajo/fcc-2024-tb/data_calibrazioni/laser/'\n",
    "    print(f'Reading laser calibration runs {log_laser[sipm][gain]}')\n",
    "    create_mean_wf(log_laser[sipm][gain], path_data)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 69,
   "metadata": {},
   "outputs": [],
   "source": [
    "dt = 0.32 \n",
    "ranger = [-400, 1599] \n",
    "npoints = 6250 "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 76,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "templates builted\n"
     ]
    }
   ],
   "source": [
    "# build templates\n",
    "interS_template, interC_template, interDark, bins = mcj.get_templates(  crystal,\n",
    "                                                                        sipm_params,\n",
    "                                                                        CONFIG,\n",
    "                                                                        ranger,\n",
    "                                                                        dt,\n",
    "                                                                        nsimS=1E7,\n",
    "                                                                        nsimC=1E7,\n",
    "                                                                        dcr=False,\n",
    "                                                                        normalize=True,\n",
    "                                                                        graphics=False,\n",
    "                                                                        Laser_Calib=True,\n",
    "                                                                        run=477,)\n",
    "print('templates builted')\n",
    "\n",
    "\n",
    "def myfunc(x, c, s, t0, of):\n",
    "    return mcj.wf_function(x, interS_template, interC_template, c, s, t0, of)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 77,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "Text(0.5, 1.0, 'Templates')"
      ]
     },
     "execution_count": 77,
     "metadata": {},
     "output_type": "execute_result"
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x450 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "times = np.linspace(ranger[0], ranger[1], npoints)\n",
    "plt.plot(times, interS_template(times), label='scintillation template')\n",
    "plt.plot(times, interC_template(times), label='cherenkov template')\n",
    "plt.plot(times, interC_template(times)+interS_template(times), label='sum')\n",
    "plt.legend()\n",
    "plt.grid()\n",
    "plt.xlabel('Time [ns]')\n",
    "plt.ylabel('amplitude [mV]')\n",
    "plt.title('Templates')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": []
  },
  {
   "cell_type": "code",
   "execution_count": 78,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "signal generated\n"
     ]
    },
    {
     "data": {
      "text/plain": [
       "Text(0.5, 1.0, 'Simulation S=500pe C=100pe')"
      ]
     },
     "execution_count": 78,
     "metadata": {},
     "output_type": "execute_result"
    },
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x450 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "# generate an event\n",
    "S=500\n",
    "C=100\n",
    "Dark=10E6 #Hz\n",
    "S_signal, C_signal, Dark_signal, bins = mcj.get_templates(  crystal,\n",
    "                                                            sipm_params,\n",
    "                                                            CONFIG,\n",
    "                                                            ranger,\n",
    "                                                            dt,\n",
    "                                                            nsimS=S,\n",
    "                                                            nsimC=C,\n",
    "                                                            dcr=Dark,\n",
    "                                                            normalize=False,\n",
    "                                                            graphics=False,\n",
    "                                                            Laser_Calib=True,\n",
    "                                                            run=477,)\n",
    "WFT = S_signal(times)+C_signal(times)+Dark_signal(times)\n",
    "print('signal generated')\n",
    "\n",
    "times = np.linspace(ranger[0], ranger[1], npoints)\n",
    "plt.plot(times, S_signal(times), label='scintillation')\n",
    "plt.plot(times, C_signal(times), label='cherenkov')\n",
    "plt.plot(times, Dark_signal(times), label='dark counts')\n",
    "plt.plot(times, S_signal(times)+C_signal(times)+Dark_signal(times), label='sum')\n",
    "plt.legend()\n",
    "plt.grid()\n",
    "plt.xlabel('Time [ns]')\n",
    "plt.ylabel('amplitude [mV]')\n",
    "plt.title(f'Simulation S={S}pe C={C}pe')\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": []
  },
  {
   "cell_type": "code",
   "execution_count": 84,
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 800x450 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "sigmas = np.std(Dark_signal(times))\n",
    "\n",
    "least_squares = LeastSquares(times, WFT, sigmas, myfunc)\n",
    "m = Minuit(least_squares, 100, 100, 0, 0)\n",
    "m.fixed['of'] = True\n",
    "m.migrad() \n",
    "\n",
    "fit_info = [f\"$\\\\chi^2$ / $n_\\\\mathrm{{dof}}$ = {m.fval:.1f} / {m.ndof:.0f} = {m.fval/m.ndof:.2f}\" ]\n",
    "plt.scatter(times, WFT, s=1, color='black', label=\"data\")\n",
    "plt.plot(times, myfunc(times, *m.values), label=\"total\", color='red')\n",
    "plt.plot(times, myfunc(times, m.values['c'], 0, m.values['t0'], m.values['of']), label=f\"Cherenkov ({m.values['c']} pe)\", color='C0')\n",
    "plt.plot(times, myfunc(times, 0, m.values['s'], m.values['t0'], m.values['of']), label=f\"Scintillation ({m.values['c']} pe)\", color='C1')\n",
    "\n",
    "plt.legend(title=\"\\n\".join(fit_info), fontsize=12, title_fontsize=12)\n",
    "plt.xlabel('Time [ns]', fontsize=16)\n",
    "plt.ylabel('Amplitude [mV]', fontsize=16)\n",
    "plt.xticks(fontsize=14)\n",
    "plt.yticks(fontsize=14)\n",
    "#plt.title(f'BGO - 10GeV e+ - theta={theta}, run {run_index}, event {event} ', size=16)\n",
    "#plt.axvline(x=m.values['x0'])\n",
    "plt.grid()\n",
    "#plt.xlim(-150, 50)\n",
    "plt.show()\n"
   ]
  },
